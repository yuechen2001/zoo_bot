project_id     = "your-gcp-project-id"
region         = "us-east1"
zone           = "us-east1-b"
ssh_user       = "ubuntu"
ssh_public_key = "ssh-rsa AAAA..."   # paste contents of ~/.ssh/id_rsa.pub

bot_token      = "your-telegram-bot-token"
admin_ids      = "537356731"

# For private repo: "https://YOUR_GITHUB_TOKEN@github.com/yuechen2001/zoo_bot.git"
repo_url       = "https://github.com/yuechen2001/zoo_bot.git"

# Mini App domain (set a CNAME in Cloudflare: zoo.yourdomain.com → <tunnel-id>.cfargotunnel.com)
webapp_domain  = "zoo.yourdomain.com"
webapp_url     = "https://zoo.yourdomain.com"

# Cloudflare Tunnel — generate once locally:
#   brew install cloudflare/cloudflare/cloudflared
#   cloudflared tunnel login
#   cloudflared tunnel create zoo          # prints the tunnel UUID
#   cat ~/.cloudflared/<UUID>.json         # paste below
cloudflare_tunnel_id          = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
cloudflare_tunnel_credentials = '{"AccountTag":"...","TunnelSecret":"...","TunnelID":"..."}'
