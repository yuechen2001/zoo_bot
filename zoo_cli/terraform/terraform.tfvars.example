project_id     = "your-gcp-project-id"
region         = "us-east1"
zone           = "us-east1-b"
ssh_user       = "ubuntu"
ssh_public_key = "ssh-rsa AAAA..."   # paste contents of ~/.ssh/id_rsa.pub

bot_token      = "your-telegram-bot-token"
admin_ids      = "537356731"

# For private repo: "https://YOUR_GITHUB_TOKEN@github.com/yuechen2001/zoo_bot.git"
repo_url       = "https://github.com/yuechen2001/zoo_bot.git"

# Cloudflare Pages URL — set after creating the Pages project in the dashboard.
# Also set VM_IP and API_SECRET as environment variables in the Pages project settings.
webapp_url     = "https://your-project.pages.dev"

# Shared secret between the Cloudflare Pages Function and this API.
# Generate with: openssl rand -hex 32
# Also set API_SECRET in the Cloudflare Pages project environment variables.
api_secret     = "your-random-secret-here"
