DATABASE_PATH=../zoo_cli/zoo_bot.db
BOT_TOKEN=your_bot_token_here
WEBAPP_ORIGIN=*
ZOO_BOT_PATH=../zoo_cli

# Shared secret injected by Cloudflare Pages Function — rejects requests missing this header.
# Generate with: openssl rand -hex 32
API_SECRET=

# Local dev only — bypasses Telegram auth. Never set this in production.
# DEV_USER_ID=your_telegram_user_id
